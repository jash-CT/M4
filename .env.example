# Database (required for API)
DATABASE_URL=postgresql://user:password@localhost:5432/logistics

# JWT for admin and vendor auth
JWT_SECRET=change-me-in-production-use-a-long-random-secret
JWT_EXPIRES=7d

# API server
PORT=3001
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Frontend (for packages/web)
NEXT_PUBLIC_API_URL=http://localhost:3001/api
